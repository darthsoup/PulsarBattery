<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PulsarBattery.Controls.TranslatedTextBlock"
    x:Name="_root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <TextBlock x:Name="_textBlock"
               HorizontalAlignment="{x:Bind _root.HorizontalAlignment, Mode=OneWay}"
               VerticalAlignment="{x:Bind _root.VerticalAlignment, Mode=OneWay}"
               Foreground="{x:Bind _root.Foreground, Mode=OneWay}"
               TextWrapping="{x:Bind TextWrapping, Mode=OneWay}"
               TextTrimming="{x:Bind TextTrimming, Mode=OneWay}"
               TextAlignment="{x:Bind TextAlignment, Mode=OneWay}"
               MaxWidth="{x:Bind MaxWidth, Mode=OneWay}"
               Style="{x:Bind TextStyle, Mode=OneWay}" />

</UserControl>
