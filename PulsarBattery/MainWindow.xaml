<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PulsarBattery.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PulsarBattery"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Pulsar Battery">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Pulsar Battery"
            Grid.Row="0"
            Height="48"
            MinHeight="48"
            MaxHeight="48"
            Background="Transparent"
            BackgroundSizing="OuterBorderEdge">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/StoreLogo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsSettingsVisible="True"
            PaneDisplayMode="LeftCompact"
            IsPaneToggleButtonVisible="False"
            IsBackButtonVisible="Collapsed"
            AlwaysShowHeader="False"
            IsTabStop="False"
            SelectionChanged="NavView_SelectionChanged"
            SelectionFollowsFocus="Enabled">

            <Frame x:Name="ContentFrame" />

            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="DashboardItem"
                    Content="Dashboard"
                    Icon="Home"
                    Tag="dashboard" />
                <NavigationViewItem Content="History">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Tag>history</NavigationViewItem.Tag>
                </NavigationViewItem>
            </NavigationView.MenuItems>

        </NavigationView>
    </Grid>
</Window>
