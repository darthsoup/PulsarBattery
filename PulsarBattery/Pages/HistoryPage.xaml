<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PulsarBattery.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PulsarBattery.Controls"
    xmlns:models="using:PulsarBattery.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="32,24,32,32">
            <StackPanel Spacing="16" MaxWidth="1000">

                <controls:TranslatedTextBlock Text="History" TextStyle="{ThemeResource TitleTextBlockStyle}" />

                <!-- History Section Header -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4"
                                VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.HistoryCountText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button x:Name="PreviousButton"
                                Click="PreviousPage_Click"
                                IsEnabled="{x:Bind ViewModel.CanGoToPreviousHistoryPage, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.HistoryPageText, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button x:Name="NextButton"
                                Click="NextPage_Click"
                                IsEnabled="{x:Bind ViewModel.CanGoToNextHistoryPage, Mode=OneWay}" />
                        <Button x:Name="ClearButton"
                                Click="ClearHistory_Click" />
                    </StackPanel>
                </Grid>

                <!-- History List -->
                <ListView ItemsSource="{x:Bind ViewModel.PagedHistory, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          Background="Transparent"
                          Padding="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:BatteryReading">
                            <Border Style="{StaticResource PulsarCardStyle}"
                                    Padding="16">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Time icon and timestamp -->
                                    <FontIcon Grid.Column="0"
                                              Glyph="&#xE823;" 
                                              FontSize="16"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="1" 
                                               Text="{x:Bind FormattedTimestamp}"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               VerticalAlignment="Center" />

                                    <!-- Battery percentage with icon -->
                                    <StackPanel Grid.Column="2" 
                                                Orientation="Horizontal" 
                                                Spacing="6"
                                                VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE83F;" 
                                                  FontSize="14"
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{x:Bind Percentage}" /><Run Text="%" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Charging status badge -->
                                    <Border Grid.Column="3"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xEBAA;" 
                                                      FontSize="12"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind ChargingStatus}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Model name -->
                                    <TextBlock Grid.Column="4" 
                                               Text="{x:Bind Model}" 
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>


                <!-- Empty state -->
                <Border Style="{StaticResource PulsarCardStyle}"
                        Padding="60,80"
                        MinHeight="300"
                        Visibility="{x:Bind ViewModel.HistoryEmptyVisibility, Mode=OneWay}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="16">
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="28"
                                Width="56"
                                Height="56"
                                HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE81C;" 
                                      FontSize="28"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <controls:TranslatedTextBlock Text="No history yet"
                                                      TextStyle="{ThemeResource SubtitleTextBlockStyle}"
                                                      HorizontalAlignment="Center" />
                        <controls:TranslatedTextBlock Text="Battery readings will appear here as your Pulsar mouse is monitored over time."
                                                      TextStyle="{ThemeResource CaptionTextBlockStyle}"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                      TextAlignment="Center"
                                                      TextWrapping="Wrap"
                                                      HorizontalAlignment="Center"
                                                      MaxWidth="400" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
