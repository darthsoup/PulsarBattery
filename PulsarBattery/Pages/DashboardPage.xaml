<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PulsarBattery.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PulsarBattery.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="32,24,32,32">
            <StackPanel Spacing="24" MaxWidth="1000">

                <controls:TranslatedTextBlock Text="Dashboard" TextStyle="{ThemeResource TitleTextBlockStyle}" />

                <!-- Loading indicator (shown when no data is available yet) -->
                <Border Style="{StaticResource PulsarCardStyle}"
                        Padding="40"
                        MinHeight="200"
                        Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}">
                    <StackPanel HorizontalAlignment="Center" 
                                VerticalAlignment="Center" 
                                Spacing="16">
                        <ProgressRing IsActive="True" 
                                      Width="48" 
                                      Height="48" />
                        <controls:TranslatedTextBlock Text="Loading battery information..."
                                                      TextStyle="{ThemeResource BodyStrongTextBlockStyle}"
                                                      HorizontalAlignment="Center" />
                        <controls:TranslatedTextBlock Text="Please wait while we connect to your device"
                                                      TextStyle="{ThemeResource CaptionTextBlockStyle}"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                      HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- No Device Found indicator -->
                <Border Style="{StaticResource PulsarCardStyle}"
                        Padding="40"
                        MinHeight="300"
                        Visibility="{x:Bind ViewModel.NoDeviceVisibility, Mode=OneWay}">
                    <StackPanel HorizontalAlignment="Center" 
                                VerticalAlignment="Center" 
                                Spacing="20">
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="32"
                                Width="64"
                                Height="64"
                                HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE7EF;" 
                                      FontSize="32"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <controls:TranslatedTextBlock Text="No Pulsar mouse detected"
                                                      TextStyle="{ThemeResource TitleTextBlockStyle}"
                                                      HorizontalAlignment="Center" />
                        <StackPanel Spacing="8" MaxWidth="450">
                            <controls:TranslatedTextBlock Text="Make sure your Pulsar mouse is connected and powered on."
                                                          TextStyle="{ThemeResource BodyTextBlockStyle}"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                          TextAlignment="Center"
                                                          TextWrapping="Wrap"
                                                          HorizontalAlignment="Center" />
                            <controls:TranslatedTextBlock Text="Supported devices: X2 CrazyLight, X2 V1"
                                                          TextStyle="{ThemeResource CaptionTextBlockStyle}"
                                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                          TextAlignment="Center"
                                                          TextWrapping="Wrap"
                                                          HorizontalAlignment="Center"
                                                          Margin="0,8,0,0" />
                        </StackPanel>
                        <Button x:Name="RetryButton"
                                Style="{ThemeResource AccentButtonStyle}"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Click="RetryConnection_Click" />
                    </StackPanel>
                </Border>

                <!-- Main content (shown when data is available) -->
                <StackPanel Spacing="24" Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}">

                    <!-- Battery Status Card -->
                    <Grid>
                        <!-- Loading indicator when refreshing with cached data -->
                        <StackPanel Orientation="Horizontal" 
                                    Spacing="8" 
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,8,16,0"
                                    Visibility="{x:Bind ViewModel.RefreshingVisibility, Mode=OneWay}">
                            <ProgressRing IsActive="True" 
                                          Width="16" 
                                          Height="16" />
                            <controls:TranslatedTextBlock Text="Updating..."
                                                          TextStyle="{ThemeResource CaptionTextBlockStyle}"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                          VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Main battery card -->
                        <Border Style="{StaticResource PulsarCardStyle}"
                                Padding="16"
                                MinHeight="120">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Left side - Battery info -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewModel.ModelName, Mode=OneWay}" 
                                               Style="{ThemeResource TitleTextBlockStyle}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind ViewModel.ChargingStateText, Mode=OneWay}" 
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.LastUpdatedText, Mode=OneWay}" 
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>

                                <!-- Right side - Large percentage -->
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           FontSize="56"
                                           FontWeight="SemiBold"
                                           Margin="24,0,0,0">
                                    <Run Text="{x:Bind ViewModel.BatteryPercentage, Mode=OneWay}" /><Run Text="%" FontSize="40" />
                                </TextBlock>

                                <!-- Progress bar (full width) -->
                                <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                             Minimum="0" 
                                             Maximum="100"
                                             Value="{x:Bind ViewModel.BatteryPercentage, Mode=OneWay}"
                                             Height="6"
                                             Margin="0,16,0,0" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Device Information Section -->
                    <StackPanel Spacing="4">
                        <controls:TranslatedTextBlock Text="Device information"
                                                      TextStyle="{ThemeResource BodyStrongTextBlockStyle}"
                                                      Margin="0,0,0,8" />

                        <!-- Model -->
                        <Border Style="{StaticResource PulsarCardStyle}"
                                Padding="16"
                                Margin="0,0,0,2">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE962;" 
                                          FontSize="16"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />

                                <controls:TranslatedTextBlock Grid.Column="1"
                                                              Text="Model"
                                                              TextStyle="{ThemeResource BodyStrongTextBlockStyle}"
                                                              VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" 
                                           Text="{x:Bind ViewModel.ModelName, Mode=OneWay}" 
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Battery Level -->
                        <Border Style="{StaticResource PulsarCardStyle}"
                                Padding="16"
                                Margin="0,0,0,2">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0"
                                          Glyph="&#xECBF;" 
                                          FontSize="16"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />

                                <controls:TranslatedTextBlock Grid.Column="1"
                                                              Text="Battery level"
                                                              TextStyle="{ThemeResource BodyStrongTextBlockStyle}"
                                                              VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" 
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="{x:Bind ViewModel.BatteryPercentage, Mode=OneWay}" /><Run Text="%" />
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Charging Status -->
                        <Border Style="{StaticResource PulsarCardStyle}"
                                Padding="16"
                                Margin="0,0,0,2">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE7E8;" 
                                          FontSize="16"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />

                                <controls:TranslatedTextBlock Grid.Column="1"
                                                              Text="Charging status"
                                                              TextStyle="{ThemeResource BodyStrongTextBlockStyle}"
                                                              VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" 
                                           Text="{x:Bind ViewModel.ChargingStateText, Mode=OneWay}" 
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Last Updated -->
                        <Border Style="{StaticResource PulsarCardStyle}"
                                Padding="16"
                                Margin="0,0,0,2">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE917;" 
                                          FontSize="16"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />

                                <controls:TranslatedTextBlock Grid.Column="1"
                                                              Text="Last updated"
                                                              TextStyle="{ThemeResource BodyStrongTextBlockStyle}"
                                                              VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" 
                                           Text="{x:Bind ViewModel.LastUpdatedText, Mode=OneWay}" 
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>

                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
