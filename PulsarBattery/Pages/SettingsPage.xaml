<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PulsarBattery.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:PulsarBattery.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:DoubleToIntConverter x:Key="DoubleToIntConverter" />
    </Page.Resources>

    <ScrollViewer x:Name="RootScrollViewer" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="RootGrid"
              Padding="32,24,32,32"
              Background="Transparent"
              PointerPressed="RootGrid_PointerPressed">
            <StackPanel Spacing="24" MaxWidth="1000">

                <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />

                <!-- Monitoring Section -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Monitoring"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,4" />

                    <controls:SettingsCard
                        Header="Battery check interval"
                        Description="How often the app polls the device and updates the dashboard">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <NumberBox Minimum="1"
                                       Maximum="120"
                                       SmallChange="1"
                                       SpinButtonPlacementMode="Compact"
                                       Value="{Binding PollIntervalMinutes, Mode=TwoWay}"
                                       Width="120" />
                            <TextBlock Text="min"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </controls:SettingsCard>

                    <controls:SettingsCard
                        Header="Log interval"
                        Description="How often readings are added to history">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <NumberBox Minimum="1"
                                       Maximum="240"
                                       SmallChange="1"
                                       SpinButtonPlacementMode="Compact"
                                       Value="{Binding LogIntervalMinutes, Mode=TwoWay}"
                                       Width="120" />
                            <TextBlock Text="min"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </controls:SettingsCard>
                </StackPanel>

                <!-- Notifications Section -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Notifications"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,4" />

                    <controls:SettingsExpander
                        Header="Low battery alerts"
                        Description="Configure thresholds, sound, and cooldown for low-battery notifications">
                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard Header="Alert threshold (unlocked)">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <NumberBox Minimum="1"
                                               Maximum="100"
                                               SmallChange="1"
                                               SpinButtonPlacementMode="Compact"
                                               Value="{Binding AlertThresholdUnlockedPercent, Mode=TwoWay, Converter={StaticResource DoubleToIntConverter}}"
                                               Width="120" />
                                    <TextBlock Text="%"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Alert threshold (locked)">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <NumberBox Minimum="1"
                                               Maximum="100"
                                               SmallChange="1"
                                               SpinButtonPlacementMode="Compact"
                                               Value="{Binding AlertThresholdLockedPercent, Mode=TwoWay, Converter={StaticResource DoubleToIntConverter}}"
                                               Width="120" />
                                    <TextBlock Text="%"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Alert cooldown">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <NumberBox Minimum="0"
                                               Maximum="1440"
                                               SpinButtonPlacementMode="Compact"
                                               Value="{Binding AlertCooldownMinutes, Mode=TwoWay}"
                                               Width="120" />
                                    <TextBlock Text="min"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Enable beeps">
                                <ToggleSwitch IsOn="{Binding EnableBeeps, Mode=TwoWay}"
                                              OnContent="On"
                                              OffContent="Off" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Alert sound">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBox Text="{Binding LowBatterySoundDisplay}"
                                             IsReadOnly="True"
                                             TextWrapping="NoWrap"
                                             Width="200" />
                                    <Button Content="Choose" Click="ChooseLowBatterySound_Click" />
                                    <Button Content="Clear" Click="ClearLowBatterySound_Click" />
                                </StackPanel>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <controls:SettingsCard
                        Header="Quick actions"
                        Description="Send a test Windows notification or refresh the battery reading"
                        ContentAlignment="Left">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Send low battery test"
                                        Click="SendLowBatteryTest_Click"
                                        Style="{ThemeResource AccentButtonStyle}" />
                                <Button Content="Refresh battery status"
                                        Click="RefreshBatteryStatus_Click" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding StatusText}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding LastUpdatedText}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </controls:SettingsCard>
                </StackPanel>

                <!-- Window Behavior Section -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Window Behavior"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,4" />

                    <controls:SettingsCard
                        Header="Minimize to tray on close"
                        Description="When enabled, clicking the window close button minimizes to system tray. When disabled, the application will exit.">
                        <ToggleSwitch IsOn="{Binding MinimizeToTrayOnClose, Mode=TwoWay}"
                                      OnContent="On"
                                      OffContent="Off" />
                    </controls:SettingsCard>

                    <controls:SettingsCard
                        Header="Start with Windows"
                        Description="Launches Pulsar Battery in the background when you sign in.">
                        <ToggleSwitch x:Name="StartWithWindowsToggle"
                                      IsOn="{Binding StartWithWindows, Mode=OneWay}"
                                      Toggled="StartWithWindowsToggle_Toggled"
                                      OnContent="On"
                                      OffContent="Off" />
                    </controls:SettingsCard>
                </StackPanel>

                <!-- About Section -->
                <StackPanel Spacing="4">
                    <TextBlock Text="About"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,4" />

                    <controls:SettingsExpander
                        Header="Pulsar Battery"
                        Description="&#169; 2026 darthsoup">
                        <controls:SettingsExpander.HeaderIcon>
                            <ImageIcon Source="/Assets/StoreLogo.png" />
                        </controls:SettingsExpander.HeaderIcon>

                        <TextBlock Text="{x:Bind AppVersion}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />

                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard
                                Header="View on GitHub"
                                Description="github.com/darthsoup/PulsarBattery"
                                IsClickEnabled="True"
                                Click="GitHubCard_Click">
                                <controls:SettingsCard.ActionIcon>
                                    <FontIcon Glyph="&#xE8A7;" />
                                </controls:SettingsCard.ActionIcon>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>
                </StackPanel>

            </StackPanel>
            <Button x:Name="FocusSink"
                    Width="1"
                    Height="1"
                    Opacity="0"
                    IsHitTestVisible="False"
                    TabIndex="-1" />
        </Grid>
    </ScrollViewer>
</Page>
